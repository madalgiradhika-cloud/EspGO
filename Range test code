// ==================== WEBSOCKET FUNCTIONS ====================
#include <WebSocketsServer.h>

WebSocketsServer webSocket = WebSocketsServer(81);

void webSocketEvent(uint8_t num, WStype_t type, uint8_t * payload, size_t length) {
  switch(type) {
    case WStype_DISCONNECTED:
      Serial.printf("[%u] Disconnected!\n", num);
      break;
      
    case WStype_CONNECTED: {
      IPAddress ip = webSocket.remoteIP(num);
      Serial.printf("[%u] Connected from %d.%d.%d.%d\n", num, ip[0], ip[1], ip[2], ip[3]);
      break;
    }
    
    case WStype_TEXT: {
      StaticJsonDocument<256> doc;
      DeserializationError error = deserializeJson(doc, payload);
      
      if (!error) {
        String command = doc["command"];
        
        if (command == "set_distance") {
          int distance = doc["value"];
          startManualTest(distance);
        }
        else if (command == "start_test") {
          int distance = doc["value"];
          startManualTest(distance);
        }
        else if (command == "record") {
          recordTestPoint();
        }
        else if (command == "start_automated") {
          startAutomatedTest();
        }
        else if (command == "start_range") {
          startRangeLimitTest();
        }
        else if (command == "start_comparison") {
          startComparisonTest();
        }
        else if (command == "calibrate") {
          performCalibration();
        }
        else if (command == "export") {
          printTestSummary();
        }
        else if (command == "get_status") {
          // Status already sent via broadcast
        }
      }
      break;
    }
  }
}

void sendStatusUpdate() {
  if (millis() - lastDataUpdate > 200) {
    StaticJsonDocument<512> doc;
    doc["ultrasonic"] = ultrasonicRaw;
    doc["tof"] = tofRaw;
    doc["usAccuracy"] = ultrasonicStdDev;
    doc["tofAccuracy"] = tofStdDev;
    doc["usSamples"] = sampleCount;
    doc["usAvg"] = ultrasonicAvg;
    doc["usStdDev"] = ultrasonicStdDev;
    doc["tofSamples"] = sampleCount;
    doc["tofAvg"] = tofAvg;
    doc["tofStdDev"] = tofStdDev;
    
    String jsonString;
    serializeJson(doc, jsonString);
    webSocket.broadcastTXT(jsonString);
    lastDataUpdate = millis();
  }
}

// ==================== SETUP & LOOP ====================
void setup() {
  Serial.begin(115200);
  Serial.println("\n\n=== ESP32 Sensor Range Test Suite ===");
  
  // Initialize components
  initEEPROM();
  initSensors();
  loadCalibration();
  
  // Initialize WiFi
  WiFi.softAP(ssid, password);
  Serial.println("WiFi AP started");
  Serial.print("IP Address: ");
  Serial.println(WiFi.softAPIP());
  
  // Initialize web server
  setupWebServer();
  webSocket.begin();
  webSocket.onEvent(webSocketEvent);
  
  // Initialize status LED
  pinMode(STATUS_LED, OUTPUT);
  
  Serial.println("\n=== Ready for Testing ===");
  Serial.println("Connect to WiFi: ESP32_RangeTest");
  Serial.println("Open browser: http://192.168.4.1");
}

void loop() {
  // Update services
  webSocket.loop();
  server.handleClient();
  
  // Read sensors
  if (millis() - lastSensorRead > 50) {
    readSensors();
    calculateStatistics();
    lastSensorRead = millis();
  }
  
  // Run active tests
  switch(currentMode) {
    case MODE_AUTOMATED_TEST:
      runAutomatedTest();
      break;
    case MODE_RANGE_LIMIT_TEST:
      runRangeLimitTest();
      break;
    case MODE_COMPARISON_TEST:
      runComparisonTest();
      break;
    default:
      break;
  }
  
  // Send status to clients
  sendStatusUpdate();
  
  // Blink status LED
  static unsigned long lastBlink = 0;
  if (millis() - lastBlink > 1000) {
    digitalWrite(STATUS_LED, !digitalRead(STATUS_LED));
    lastBlink = millis();
  }
  
  delay(10);
}
