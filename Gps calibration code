// ==================== GPS CALIBRATION FUNCTIONS ====================
void initEEPROM() {
  EEPROM.begin(EEPROM_SIZE);
  Serial.println("EEPROM initialized");
}

void saveGPSCalibration() {
  EEPROM.put(GPS_OFFSET_LAT_ADDR, gpsCal.latOffset);
  EEPROM.put(GPS_OFFSET_LNG_ADDR, gpsCal.lngOffset);
  EEPROM.put(GPS_ACCURACY_ADDR, gpsCal.accuracy);
  EEPROM.put(GPS_CALIBRATION_ADDR, gpsCal.isCalibrated);
  EEPROM.commit();
  Serial.println("GPS calibration saved to EEPROM");
  Serial.printf("Saved offsets: Lat=%.6f, Lng=%.6f\n", gpsCal.latOffset, gpsCal.lngOffset);
}

void loadGPSCalibration() {
  EEPROM.get(GPS_OFFSET_LAT_ADDR, gpsCal.latOffset);
  EEPROM.get(GPS_OFFSET_LNG_ADDR, gpsCal.lngOffset);
  EEPROM.get(GPS_ACCURACY_ADDR, gpsCal.accuracy);
  EEPROM.get(GPS_CALIBRATION_ADDR, gpsCal.isCalibrated);
  
  if (gpsCal.isCalibrated) {
    Serial.println("GPS calibration loaded from EEPROM");
    Serial.printf("Loaded offsets: Lat=%.6f, Lng=%.6f\n", gpsCal.latOffset, gpsCal.lngOffset);
    Serial.printf("Calibration accuracy: %.2f meters\n", gpsCal.accuracy);
    robotStatus = "GPS Calibration loaded. Accuracy: " + String(gpsCal.accuracy) + "m";
  } else {
    Serial.println("No GPS calibration found. Run calibration for better accuracy.");
    robotStatus = "GPS not calibrated. Run calibration for better accuracy.";
  }
}

void startGPSCollection() {
  if (gps.location.isValid() && gps.satellites.value() >= 4) {
    gpsCal.isCollecting = true;
    gpsCal.samplesCollected = 0;
    gpsCal.sumLat = 0;
    gpsCal.sumLng = 0;
    gpsCal.calibrationStartTime = millis();
    robotStatus = "GPS calibration started. Collecting data...";
    Serial.println("GPS calibration started. Keep robot stationary for 60 seconds.");
  } else {
    robotStatus = "Cannot calibrate: Insufficient GPS signal. Satellites: " + String(gps.satellites.value());
    Serial.println("Cannot start calibration: Insufficient GPS fix");
  }
}

void updateGPSCalibration() {
  if (!gpsCal.isCollecting) return;
  
  if (gps.location.isValid() && gps.satellites.value() >= 4) {
    gpsCal.sumLat += gps.location.lat();
    gpsCal.sumLng += gps.location.lng();
    gpsCal.samplesCollected++;
    
    // Update status every 10 samples
    if (gpsCal.samplesCollected % 10 == 0) {
      robotStatus = "Calibration: " + String(gpsCal.samplesCollected) + " samples collected";
      Serial.printf("Calibration sample %d: Lat=%.6f, Lng=%.6f\n", 
                    gpsCal.samplesCollected, gps.location.lat(), gps.location.lng());
    }
    
    // Collect for 60 seconds or 1000 samples
    if (gpsCal.samplesCollected >= 1000 || (millis() - gpsCal.calibrationStartTime) > 60000) {
      // Calculate average position
      gpsCal.fixedLat = gpsCal.sumLat / gpsCal.samplesCollected;
      gpsCal.fixedLng = gpsCal.sumLng / gpsCal.samplesCollected;
      
      // Calculate accuracy (standard deviation)
      float sumSqLat = 0, sumSqLng = 0;
      // Note: We'd need to recalculate with stored samples for accurate std dev
      // For simplicity, we'll estimate accuracy based on HDOP
      gpsCal.accuracy = gps.hdop.value() / 100.0; // HDOP in meters
      
      // Offsets will be applied during navigation
      gpsCal.latOffset = 0; // We'll use fixed point reference instead
      gpsCal.lngOffset = 0;
      gpsCal.isCalibrated = true;
      gpsCal.isCollecting = false;
      
      saveGPSCalibration();
      robotStatus = "Calibration complete! Accuracy: " + String(gpsCal.accuracy) + " meters";
      Serial.println("GPS calibration complete!");
      Serial.printf("Reference position: %.6f, %.6f\n", gpsCal.fixedLat, gpsCal.fixedLng);
      Serial.printf("Estimated accuracy: %.2f meters\n", gpsCal.accuracy);
    }
  } else if (millis() - gpsCal.calibrationStartTime > 60000) {
    // Timeout without good fix
    gpsCal.isCollecting = false;
    robotStatus = "Calibration failed: No GPS fix during collection period";
    Serial.println("Calibration failed: No GPS fix");
  }
}

float getCalibratedLat() {
  float rawLat = gps.location.lat();
  if (gpsCal.isCalibrated && gpsCal.samplesCollected > 0) {
    // Apply differential correction if we have a reference point
    return rawLat - (gpsCal.fixedLat - rawLat);
  }
  return rawLat;
}

float getCalibratedLng() {
  float rawLng = gps.location.lng();
  if (gpsCal.isCalibrated && gpsCal.samplesCollected > 0) {
    return rawLng - (gpsCal.fixedLng - rawLng);
  }
  return rawLng;
}

float calculateCalibratedDistance(float lat1, float lon1, float lat2, float lon2) {
  float dLat = (lat2 - lat1) * PI / 180;
  float dLon = (lon2 - lon1) * PI / 180;
  float a = sin(dLat/2) * sin(dLat/2) + 
            cos(lat1 * PI / 180) * cos(lat2 * PI / 180) * 
            sin(dLon/2) * sin(dLon/2);
  float c = 2 * atan2(sqrt(a), sqrt(1-a));
  return 6371000 * c; // Distance in meters
}

// ==================== MOTOR CONTROL FUNCTIONS ====================
void motorControl(int leftSpeed, int rightSpeed, String direction) {
  leftSpeed = constrain(leftSpeed, -MAX_SPEED, MAX_SPEED);
  rightSpeed = constrain(rightSpeed, -MAX_SPEED, MAX_SPEED);
  
  if (direction == "FORWARD") {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
    analogWrite(ENA, abs(leftSpeed));
    analogWrite(ENB, abs(rightSpeed));
  }
  else if (direction == "BACKWARD") {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
    analogWrite(ENA, abs(leftSpeed));
    analogWrite(ENB, abs(rightSpeed));
  }
  else if (direction == "LEFT") {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
    analogWrite(ENA, TURN_SPEED);
    analogWrite(ENB, TURN_SPEED);
  }
  else if (direction == "RIGHT") {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
    analogWrite(ENA, TURN_SPEED);
    analogWrite(ENB, TURN_SPEED);
  }
  else if (direction == "STOP") {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, LOW);
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, LOW);
    analogWrite(ENA, 0);
    analogWrite(ENB, 0);
  }
}

void stopMotors() {
  motorControl(0, 0, "STOP");
}

// ==================== SENSOR FUNCTIONS ====================
int readUltrasonic() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  
  long duration = pulseIn(ECHO_PIN, HIGH, 30000);
  if (duration == 0) return 400;
  
  int distance = duration * 0.034 / 2;
  return constrain(distance, 2, 400);
}

int readVL53L0X() {
  return tofSensor.readRangeSingleMillimeters();
}

void readAllSensors() {
  ultrasonicDistance = readUltrasonic();
  tofDistance = readVL53L0X();
  frontDistance = min(ultrasonicDistance, tofDistance / 10);
  obstacleDetected = (frontDistance < 30 && frontDistance > 0);
  
  if (obstacleDetected && (currentMode == MODE_AUTONOMOUS || currentMode == MODE_GPS_NAVIGATION)) {
    robotStatus = "Obstacle detected! Distance: " + String(frontDistance) + "cm";
    avoidObstacle();
  }
}

void avoidObstacle() {
  stopMotors();
  delay(100);
  
  motorControl(0, 0, "LEFT");
  delay(500);
  int leftDist = readUltrasonic();
  stopMotors();
  
  motorControl(0, 0, "RIGHT");
  delay(500);
  int rightDist = readUltrasonic();
  stopMotors();
  
  if (leftDist > rightDist) {
    motorControl(0, 0, "LEFT");
    delay(800);
    robotStatus = "Avoiding obstacle to the left";
  } else {
    motorControl(0, 0, "RIGHT");
    delay(800);
    robotStatus = "Avoiding obstacle to the right";
  }
  
  stopMotors();
  delay(200);
}

// ==================== GPS FUNCTIONS ====================
void updateGPS() {
  while (SerialGPS.available() > 0) {
    gps.encode(SerialGPS.read());
  }
  
  if (gps.location.isValid()) {
    currentLat = getCalibratedLat();
    currentLng = getCalibratedLng();
    currentSpeed = gps.speed.kmph();
    gpsSatellites = gps.satellites.value();
    gpsHDOP = gps.hdop.value();
  }
}

float calculateBearing(float lat1, float lon1, float lat2, float lon2) {
  float dLon = (lon2 - lon1) * PI / 180;
  float y = sin(dLon) * cos(lat2 * PI / 180);
  float x = cos(lat1 * PI / 180) * sin(lat2 * PI / 180) - 
            sin(lat1 * PI / 180) * cos(lat2 * PI / 180) * cos(dLon);
  float bearing = atan2(y, x) * 180 / PI;
  if (bearing < 0) bearing += 360;
  return bearing;
}

void navigateToTarget() {
  if (!hasTarget || !gps.location.isValid()) {
    stopMotors();
    return;
  }
  
  float distanceToTarget = calculateCalibratedDistance(currentLat, currentLng, targetLat, targetLng);
  
  if (distanceToTarget < (gpsCal.accuracy + 5.0)) {
    stopMotors();
    hasTarget = false;
    robotStatus = "Target reached! (Accuracy: " + String(gpsCal.accuracy) + "m)";
    currentMode = MODE_IDLE;
    return;
  }
  
  float bearing = calculateBearing(currentLat, currentLng, targetLat, targetLng);
  float headingError = bearing - currentHeading;
  
  if (headingError > 180) headingError -= 360;
  if (headingError < -180) headingError += 360;
  
  int leftSpeed, rightSpeed;
  
  if (abs(headingError) < 10) {
    leftSpeed = BASE_SPEED;
    rightSpeed = BASE_SPEED;
    motorControl(leftSpeed, rightSpeed, "FORWARD");
  } else if (headingError > 0) {
    leftSpeed = TURN_SPEED;
    rightSpeed = TURN_SPEED / 2;
    motorControl(leftSpeed, rightSpeed, "FORWARD");
  } else {
    leftSpeed = TURN_SPEED / 2;
    rightSpeed = TURN_SPEED;
    motorControl(leftSpeed, rightSpeed, "FORWARD");
  }
  
  robotStatus = "Target: " + String(distanceToTarget, 1) + "m | Accuracy: " + String(gpsCal.accuracy, 1) + "m";
}

