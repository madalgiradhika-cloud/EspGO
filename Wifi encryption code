class SecureWebServer {
private:
  WebServer* server;
  WebSocketsServer* webSocket;
  JWTToken* jwt;
  AES256Encryption* crypto;
  
  bool checkAuthentication(WebServer& server) {
    if(!securityEnabled) return true;
    
    // Check JWT token in header
    if(server.hasHeader("Authorization")) {
      String auth = server.header("Authorization");
      if(auth.startsWith("Bearer ")) {
        String token = auth.substring(7);
        if(jwt->verifyToken(token)) {
          authenticatedClient = jwt->getUsername(token);
          return true;
        }
      }
    }
    
    // Check session cookie
    if(server.hasHeader("Cookie")) {
      String cookie = server.header("Cookie");
      int tokenStart = cookie.indexOf("token=");
      if(tokenStart != -1) {
        int tokenEnd = cookie.indexOf(";", tokenStart);
        String token = cookie.substring(tokenStart + 6, tokenEnd == -1 ? cookie.length() : tokenEnd);
        if(jwt->verifyToken(token)) {
          authenticatedClient = jwt->getUsername(token);
          return true;
        }
      }
    }
    
    // Check rate limiting
    IPAddress clientIP = server.client().remoteIP();
    if(isRateLimited(clientIP)) {
      server.send(429, "application/json", "{\"error\":\"Too many requests\"}");
      return false;
    }
    
    server.send(401, "application/json", "{\"error\":\"Unauthorized\"}");
    return false;
  }
  
  bool isRateLimited(IPAddress ip) {
    // Check if IP is blocked
    for(int i = 0; i < rateLimitCount; i++) {
      if(rateLimits[i].ip == ip) {
        if(rateLimits[i].blocked) {
          if(millis() < rateLimits[i].blockUntil) {
            return true;
          } else {
            rateLimits[i].blocked = false;
            rateLimits[i].requests = 0;
          }
        }
        
        // Update request count
        if(millis() - rateLimits[i].lastRequest < 1000) {
          rateLimits[i].requests++;
          if(rateLimits[i].requests > 60) { // 60 requests per second
            rateLimits[i].blocked = true;
            rateLimits[i].blockUntil = millis() + 60000; // Block for 1 minute
            return true;
          }
        } else {
          rateLimits[i].requests = 1;
        }
        rateLimits[i].lastRequest = millis();
        return false;
      }
    }
    
    // Add new IP to rate limiting
    if(rateLimitCount < 10) {
      rateLimits[rateLimitCount].ip = ip;
      rateLimits[rateLimitCount].requests = 1;
      rateLimits[rateLimitCount].lastRequest = millis();
      rateLimits[rateLimitCount].blocked = false;
      rateLimitCount++;
    }
    return false;
  }
  
  bool checkMACAddress(WebServer& server) {
    String clientMAC = server.client().remoteIP().toString(); // Simplified - get actual MAC in production
    int i = 0;
    while(macWhitelist[i] != NULL) {
      if(clientMAC == macWhitelist[i]) return true;
      i++;
    }
    return macWhitelist[0] == NULL; // Allow all if whitelist empty
  }
  
