// ==================== ENCRYPTION CLASS ====================
class AES256Encryption {
private:
  mbedtls_aes_context aes;
  unsigned char key[32];
  unsigned char iv[16];
  
public:
  AES256Encryption(const char* password) {
    mbedtls_aes_init(&aes);
    // Derive key from password using SHA-256
    mbedtls_sha256_context sha;
    mbedtls_sha256_init(&sha);
    mbedtls_sha256_starts(&sha, 0);
    mbedtls_sha256_update(&sha, (const unsigned char*)password, strlen(password));
    mbedtls_sha256_finish(&sha, key);
    mbedtls_sha256_free(&sha);
    
    // Generate random IV
    for(int i = 0; i < 16; i++) {
      iv[i] = esp_random() % 256;
    }
  }
  
  String encrypt(String plaintext) {
    size_t input_len = plaintext.length();
    size_t encrypted_len = ((input_len + 15) / 16) * 16;
    unsigned char* input = (unsigned char*)plaintext.c_str();
    unsigned char* output = new unsigned char[encrypted_len];
    
    mbedtls_aes_setkey_enc(&aes, key, 256);
    mbedtls_aes_crypt_cbc(&aes, MBEDTLS_AES_ENCRYPT, encrypted_len, iv, input, output);
    
    // Base64 encode
    size_t b64_len = 0;
    unsigned char* b64_output = new unsigned char[encrypted_len * 2];
    mbedtls_base64_encode(b64_output, encrypted_len * 2, &b64_len, output, encrypted_len);
    
    String result = String((char*)b64_output);
    delete[] output;
    delete[] b64_output;
    
    return result;
  }
  
  String decrypt(String ciphertext) {
    // Base64 decode
    size_t decoded_len = 0;
    unsigned char* decoded = new unsigned char[ciphertext.length()];
    mbedtls_base64_decode(decoded, ciphertext.length(), &decoded_len, 
                          (unsigned char*)ciphertext.c_str(), ciphertext.length());
    
    size_t decrypted_len = decoded_len;
    unsigned char* output = new unsigned char[decrypted_len];
    
    mbedtls_aes_setkey_dec(&aes, key, 256);
    mbedtls_aes_crypt_cbc(&aes, MBEDTLS_AES_DECRYPT, decrypted_len, iv, decoded, output);
    
    String result = String((char*)output, decrypted_len);
    delete[] decoded;
    delete[] output;
    
    return result;
  }
};

// ==================== JWT TOKEN CLASS ====================
class JWTToken {
private:
  String secret;
  
  String base64UrlEncode(const String& text) {
    String base64 = base64::encode(text);
    base64.replace("+", "-");
    base64.replace("/", "_");
    base64.replace("=", "");
    return base64;
  }
  
  String sha256(const String& text) {
    mbedtls_sha256_context ctx;
    unsigned char hash[32];
    
    mbedtls_sha256_init(&ctx);
    mbedtls_sha256_starts(&ctx, 0);
    mbedtls_sha256_update(&ctx, (const unsigned char*)text.c_str(), text.length());
    mbedtls_sha256_finish(&ctx, hash);
    mbedtls_sha256_free(&ctx);
    
    String result = "";
    for(int i = 0; i < 32; i++) {
      char hex[3];
      sprintf(hex, "%02x", hash[i]);
      result += hex;
    }
    return result;
  }
  
public:
  JWTToken(const char* jwtSecret) : secret(jwtSecret) {}
  
  String generateToken(String username, int expirySeconds = 3600) {
    // Header
    String header = "{\"alg\":\"HS256\",\"typ\":\"JWT\"}";
    String encodedHeader = base64UrlEncode(header);
    
    // Payload
    unsigned long expiry = millis() / 1000 + expirySeconds;
    String payload = "{\"sub\":\"" + username + "\",\"exp\":" + String(expiry) + ",\"iat\":" + String(millis() / 1000) + "}";
    String encodedPayload = base64UrlEncode(payload);
    
    // Signature
    String signatureInput = encodedHeader + "." + encodedPayload;
    String signature = sha256(signatureInput + secret);
    String encodedSignature = base64UrlEncode(signature);
    
    return encodedHeader + "." + encodedPayload + "." + encodedSignature;
  }
  
  bool verifyToken(String token) {
    int firstDot = token.indexOf('.');
    int lastDot = token.lastIndexOf('.');
    
    if(firstDot == -1 || lastDot == -1 || firstDot == lastDot) return false;
    
    String encodedHeader = token.substring(0, firstDot);
    String encodedPayload = token.substring(firstDot + 1, lastDot);
    String encodedSignature = token.substring(lastDot + 1);
    
    String signatureInput = encodedHeader + "." + encodedPayload;
    String expectedSignature = sha256(signatureInput + secret);
    String encodedExpected = base64UrlEncode(expectedSignature);
    
    return encodedSignature == encodedExpected;
  }
  
  String getUsername(String token) {
    int firstDot = token.indexOf('.');
    int lastDot = token.lastIndexOf('.');
    
    if(firstDot == -1 || lastDot == -1) return "";
    
    String encodedPayload = token.substring(firstDot + 1, lastDot);
    String payload = base64::decode(encodedPayload);
    
    StaticJsonDocument<256> doc;
    deserializeJson(doc, payload);
    
    return doc["sub"].as<String>();
  }
};

// ==================== SECURE STORAGE CLASS ====================
class SecureStorage {
private:
  AES256Encryption crypto;
  
public:
  SecureStorage(const char* key) : crypto(key) {}
  
  void saveSecure(const char* key, String value) {
    String encrypted = crypto.encrypt(value);
    EEPROM.put(getAddress(key), encrypted);
    EEPROM.commit();
  }
  
  String loadSecure(const char* key) {
    String encrypted;
    EEPROM.get(getAddress(key), encrypted);
    if(encrypted.length() > 0) {
      return crypto.decrypt(encrypted);
    }
    return "";
  }
  
private:
  int getAddress(const char* key) {
    // Simple hash to get address
    int hash = 0;
    while(*key) {
      hash = (hash * 31) + *key++;
    }
    return abs(hash) % (EEPROM_SIZE - 256);
  }
};

