// ==================== MOTOR CONTROL FUNCTIONS ====================
void motorControl(int leftSpeed, int rightSpeed, String direction) {
  // Constrain speeds
  leftSpeed = constrain(leftSpeed, -MAX_SPEED, MAX_SPEED);
  rightSpeed = constrain(rightSpeed, -MAX_SPEED, MAX_SPEED);
  
  if (direction == "FORWARD") {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
    analogWrite(ENA, abs(leftSpeed));
    analogWrite(ENB, abs(rightSpeed));
  }
  else if (direction == "BACKWARD") {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
    analogWrite(ENA, abs(leftSpeed));
    analogWrite(ENB, abs(rightSpeed));
  }
  else if (direction == "LEFT") {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
    analogWrite(ENA, TURN_SPEED);
    analogWrite(ENB, TURN_SPEED);
  }
  else if (direction == "RIGHT") {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
    analogWrite(ENA, TURN_SPEED);
    analogWrite(ENB, TURN_SPEED);
  }
  else if (direction == "STOP") {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, LOW);
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, LOW);
    analogWrite(ENA, 0);
    analogWrite(ENB, 0);
  }
}

void stopMotors() {
  motorControl(0, 0, "STOP");
}

// ==================== SENSOR FUNCTIONS ====================
int readUltrasonic() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  
  long duration = pulseIn(ECHO_PIN, HIGH, 30000); // 30ms timeout
  if (duration == 0) return 400; // No echo, return max distance
  
  int distance = duration * 0.034 / 2;
  return constrain(distance, 2, 400);
}

int readVL53L0X() {
  return tofSensor.readRangeSingleMillimeters();
}

void readAllSensors() {
  // Read HC-SR04
  ultrasonicDistance = readUltrasonic();
  
  // Read VL53L0X (Time-of-Flight)
  tofDistance = readVL53L0X();
  
  // Use the smaller distance for obstacle detection (more conservative)
  frontDistance = min(ultrasonicDistance, tofDistance / 10); // Convert mm to cm
  
  // Check for obstacles (threshold 30cm)
  obstacleDetected = (frontDistance < 30 && frontDistance > 0);
  
  if (obstacleDetected && currentMode == MODE_AUTONOMOUS) {
    robotStatus = "Obstacle detected! Distance: " + String(frontDistance) + "cm";
    avoidObstacle();
  }
}

void avoidObstacle() {
  stopMotors();
  delay(100);
  
  // Scan left and right
  motorControl(0, 0, "LEFT");
  delay(500);
  int leftDist = readUltrasonic();
  stopMotors();
  
  motorControl(0, 0, "RIGHT");
  delay(500);
  int rightDist = readUltrasonic();
  stopMotors();
  
  // Choose best direction
  if (leftDist > rightDist) {
    motorControl(0, 0, "LEFT");
    delay(800);
    robotStatus = "Avoiding obstacle to the left";
  } else {
    motorControl(0, 0, "RIGHT");
    delay(800);
    robotStatus = "Avoiding obstacle to the right";
  }
  
  stopMotors();
  delay(200);
}

// ==================== GPS FUNCTIONS ====================
void updateGPS() {
  while (SerialGPS.available() > 0) {
    gps.encode(SerialGPS.read());
  }
  
  if (gps.location.isValid()) {
    currentLat = gps.location.lat();
    currentLng = gps.location.lng();
    currentSpeed = gps.speed.kmph();
    gpsSatellites = gps.satellites.value();
  }
}

float calculateBearing(float lat1, float lon1, float lat2, float lon2) {
  float dLon = (lon2 - lon1) * PI / 180;
  float y = sin(dLon) * cos(lat2 * PI / 180);
  float x = cos(lat1 * PI / 180) * sin(lat2 * PI / 180) - 
            sin(lat1 * PI / 180) * cos(lat2 * PI / 180) * cos(dLon);
  float bearing = atan2(y, x) * 180 / PI;
  if (bearing < 0) bearing += 360;
  return bearing;
}

float calculateDistance(float lat1, float lon1, float lat2, float lon2) {
  float dLat = (lat2 - lat1) * PI / 180;
  float dLon = (lon2 - lon1) * PI / 180;
  float a = sin(dLat/2) * sin(dLat/2) + 
            cos(lat1 * PI / 180) * cos(lat2 * PI / 180) * 
            sin(dLon/2) * sin(dLon/2);
  float c = 2 * atan2(sqrt(a), sqrt(1-a));
  return 6371000 * c; // Distance in meters
}

void navigateToTarget() {
  if (!hasTarget || !gps.location.isValid()) {
    stopMotors();
    return;
  }
  
  float distanceToTarget = calculateDistance(currentLat, currentLng, targetLat, targetLng);
  
  if (distanceToTarget < 5.0) { // Within 5 meters
    stopMotors();
    hasTarget = false;
    robotStatus = "Target reached!";
    currentMode = MODE_IDLE;
    return;
  }
  
  float bearing = calculateBearing(currentLat, currentLng, targetLat, targetLng);
  float headingError = bearing - currentHeading;
  
  // Normalize heading error
  if (headingError > 180) headingError -= 360;
  if (headingError < -180) headingError += 360;
  
  // Adjust motor speeds based on heading error
  int leftSpeed, rightSpeed;
  
  if (abs(headingError) < 10) {
    // Go straight
    leftSpeed = BASE_SPEED;
    rightSpeed = BASE_SPEED;
    motorControl(leftSpeed, rightSpeed, "FORWARD");
  } else if (headingError > 0) {
    // Turn right
    leftSpeed = TURN_SPEED;
    rightSpeed = TURN_SPEED / 2;
    motorControl(leftSpeed, rightSpeed, "FORWARD");
  } else {
    // Turn left
    leftSpeed = TURN_SPEED / 2;
    rightSpeed = TURN_SPEED;
    motorControl(leftSpeed, rightSpeed, "FORWARD");
  }
  
  robotStatus = "Navigating to target. Distance: " + String(distanceToTarget) + "m";
}

